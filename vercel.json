{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/v1/(.*)",
            "destination": "/api/main.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/backend/static/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/$1"
        }
    ],
    "functions": {
        "api/main.py": {
            "runtime": "vercel-python@0.1.0",
            "memory": 1024,
            "maxDuration": 60
        }
    }
}