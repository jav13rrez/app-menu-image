# CONFIGURACIÓN PARA VERCEL (ENVIRONMENT VARIABLES)

# 1. Supabase (Panel de Proyecto > Settings > API)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-service-role-key-here # ¡No la compartas!
SUPABASE_JWT_SECRET=your-jwt-secret-here # Panel de Supabase > Settings > API > JWT Settings

# 2. Google AI (Gemini)
# Imagen 3 y Gemini Pro Vision requieren este API Key
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxx

# 3. Frontend (Panel de Vercel)
# Deja NEXT_PUBLIC_API_URL vacío en producción para usar rutas relativas /api
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
